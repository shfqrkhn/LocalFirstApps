{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commonground.local/schemas/content-review-v1.json",
  "title": "CommonGround content review ledger",
  "type": "object",
  "required": ["schemaVersion", "generatedFrom", "entries", "duplicateGroups"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedFrom": { "type": "array", "items": { "type": "string" } },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "app", "kind", "location", "contentHash", "source", "license", "contentVersion", "reviewDate", "reviewer", "status", "supersedes", "evidenceStrength", "claimLimits"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "app": { "enum": ["pmquiz", "noodle-nudge", "flexx-files"] },
          "kind": { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "contentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "source": { "type": ["string", "null"] },
          "license": { "type": ["string", "null"] },
          "contentVersion": { "type": ["string", "null"] },
          "reviewDate": { "type": ["string", "null"] },
          "reviewer": { "type": ["string", "null"] },
          "status": { "enum": ["quarantined", "in-review", "approved", "retired"] },
          "supersedes": { "type": ["string", "null"] },
          "evidenceStrength": { "enum": ["unverified", "anecdotal", "secondary", "primary", "consensus"] },
          "claimLimits": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "duplicateGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["normalizedHash", "count", "entryIds"],
        "properties": {
          "normalizedHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "count": { "type": "integer", "minimum": 2 },
          "entryIds": { "type": "array", "minItems": 2, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
